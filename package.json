{
  "name": "pasterack",
  "version": "1.0.0",
  "description": "A lightweight macOS menu bar clipboard manager with secure password vault",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "prebuild": "node scripts/generate-dmg-bg.js",
    "build": "electron-builder --mac && node scripts/adhoc-sign.js",
    "build:dmg": "electron-builder --mac dmg && node scripts/adhoc-sign.js",
    "build:zip": "electron-builder --mac zip"
  },
  "author": "PasteRack",
  "license": "MIT",
  "build": {
    "appId": "com.pasterack.app",
    "productName": "PasteRack",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "darkModeSupport": true,
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "Install PasteRack",
      "background": "build/dmg-bg.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "src/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/adhoc-sign.js"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
