{
  "name": "pasterack",
  "version": "1.0.0",
  "description": "A lightweight macOS menu bar clipboard manager with secure password vault",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip"
  },
  "author": "PasteRack",
  "license": "MIT",
  "build": {
    "appId": "com.pasterack.app",
    "productName": "PasteRack",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "darkModeSupport": true,
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "PasteRack",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "src/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
